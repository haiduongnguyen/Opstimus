{
  "mode": "inference",
  "workflow": {
    "name": "inference_csv_data_only_template",
    "tags": ["template", "tabular", "data_only"]
  },
  "dataset": "csv_data_only",
  "dataset_overrides": {
    "data_path": "data/raw/your_data.csv",
    "label_col": null,
    "drop_columns": []
  },
  "inference": {
    "model_source": "profile",
    "model_profile": "tabular_inference_fast",
    "threshold_profiles": ["default", "percentile_95"],
    "use_test_only": true
  },
  "rca": {
    "enabled": true,
    "top_k": 5
  }
}
