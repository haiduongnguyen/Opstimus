{
  "experiment": {
    "name": "sklearn_breast_cancer_isolation_forest",
    "task_type": "tabular_ad_rca",
    "tags": ["sklearn", "breast_cancer", "baseline", "tabular", "isolation_forest"]
  },
  "dataset": {
    "name": "sklearn_breast_cancer",
    "path": "sklearn://breast_cancer",
    "anomaly_label": 0,
    "normal_only_train": true,
    "test_size": 0.3,
    "random_state": 42
  },
  "detector": {
    "name": "isolation_forest",
    "params": {
      "n_estimators": 100,
      "contamination": 0.35,
      "random_state": 42
    }
  },
  "threshold": {
    "strategy": "model_default"
  },
  "rca": {
    "top_k": 5
  },
  "output_dir": "artifacts/sklearn_breast_cancer/isolation_forest"
}
